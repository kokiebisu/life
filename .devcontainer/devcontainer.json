{
  "name": "Life Management",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Anthropic.claude-code",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",
        "ms-azuretools.vscode-containers",
        "GitHub.vscode-pull-request-github",
        "xshrim.txt-syntax",
        "golang.Go"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[markdown]": {
          "editor.wordWrap": "on"
        }
      }
    }
  },
  "postCreateCommand": "git config --global worktree.guessRemote true && ./scripts/gen-agents-md.sh",
  "remoteUser": "node",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/node/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.codex,target=/home/node/.codex,type=bind,consistency=cached",
    "source=vscode-server-data,target=/home/node/.vscode-server/data,type=volume",
    "source=vscode-server-extensions,target=/home/node/.vscode-server/extensions,type=volume"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}",
    "GITHUB_PERSONAL_ACCESS_TOKEN": "${localEnv:GITHUB_PERSONAL_ACCESS_TOKEN}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "CODEX_CONFIG_DIR": "/home/node/.codex",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "TZ": "Asia/Tokyo"
  }
}
