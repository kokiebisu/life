{
  "permissions": {
    "allow": [
      "mcp__*",
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run scripts/study-status.ts | jq -Rsc 'rtrimstr(\"\\n\") | select(. != \"\") | {systemMessage: .}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/humanize-check.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true
  }
}
